    };
};

/ {
  #include <dt-bindings/led/led.h>
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";  // ← Re-habilitado con frecuencia baja
    pinctrl-0 = <&spi3_right_default>;
    pinctrl-1 = <&spi3_right_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;

        /* Number of SK6812/WS2812-compatible LEDs on RIGHT half */
        chain-length = <17>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};


/ {
  chosen {
    zmk,underglow = &led_strip;
  };
};

/ {
  /* Convert X/Y mouse movement to scroll wheel */
  xy_to_scroll: xy_to_scroll {
    compatible = "zmk,input-processor-code-mapper";
    #input-processor-cells = <0>;
    type = <INPUT_EV_REL>;
    map = <INPUT_REL_X INPUT_REL_HWHEEL>
        , <INPUT_REL_Y INPUT_REL_WHEEL>;
  };

  /* Scaler for vertical scroll (negative inverts) */
  vscroll_scaler: vscroll_scaler {
    compatible = "zmk,input-processor-scaler";
    #input-processor-cells = <2>;
    type = <INPUT_EV_REL>;
    codes = <INPUT_REL_WHEEL>;
    track-remainders;
  };

  /* Scaler for horizontal scroll (positive because invert-x already inverts) */
  hscroll_scaler: hscroll_scaler {
    compatible = "zmk,input-processor-scaler";
    #input-processor-cells = <2>;
    type = <INPUT_EV_REL>;
    codes = <INPUT_REL_HWHEEL>;
    track-remainders;
  };

  /* Scaler for mouse Y movement */
  y_scaler: y_scaler {
    compatible = "zmk,input-processor-scaler";
    #input-processor-cells = <2>;
    type = <INPUT_EV_REL>;
    codes = <INPUT_REL_Y>;
    track-remainders;
  };

  /* Scaler for mouse X movement (compensate for invert-y on cursor) */
  x_scaler: x_scaler {
    compatible = "zmk,input-processor-scaler";
    #input-processor-cells = <2>;
    type = <INPUT_EV_REL>;
    codes = <INPUT_REL_X>;
    track-remainders;
  };
};

/ {
  trackball_listener {
    compatible = "zmk,input-listener";
    device = <&trackball>;

    /* Fast scroll layer - MUST be first to take priority over scroll_mode */
    fast_scroll {
        layers = <FAST>;
        input-processors = <&xy_to_scroll>, <&vscroll_scaler (-1) 4>, <&hscroll_scaler 1 4>;
    };

    /* Scroll layers - inverted both axes */
    scroll_mode {
        layers = <SCROLL SCROLLTOP>;
        input-processors = <&xy_to_scroll>, <&vscroll_scaler (-1) 20>, <&hscroll_scaler 1 20>;
    };

    /* MOUSETOP override - base speed even when SNIPE/SNIPETOP are active */
    mousetop_override {
        layers = <MOUSETOP>;
        input-processors = <&y_scaler 3 1>, <&x_scaler 3 1>;
    };

    /* Snipe mode - slower mouse */
    snipe_mode {
        layers = <SNIPE SNIPETOP>;
        input-processors = <&y_scaler 3 2>, <&x_scaler 3 2>;
    };

    /* Default mouse movement */
    default_move {
        layers = <BASE LOWER RAISE DIRECTACC FUNC ADJ NUMBERS WARP SYSTEM>;
        input-processors = <&y_scaler 3 1>, <&x_scaler 3 1>;
    };

  };
};